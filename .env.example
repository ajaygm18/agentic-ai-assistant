APP_NAME=Agentic AI Assistant
APP_ENV=local
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Chat requests go through the local Anti-API gateway in ../anti-api-main.
OPENAI_API_KEY=anti-api-local-token
LLM_BASE_URL=http://localhost:8964/v1
LLM_MODEL=gpt-5.4
PLANNER_MODEL=claude-opus-4-6
LLM_TEMPERATURE=0.2

# Embeddings default to Anti-API as well. Anti-API proxies /v1/embeddings through
# the Copilot/GitHub Models embeddings endpoint, so a working Copilot account is required there.
EMBEDDING_API_KEY=anti-api-local-token
EMBEDDING_BASE_URL=http://localhost:8964/v1
EMBEDDING_MODEL=text-embedding-3-small

DOCS_DIR=data/docs
CHROMA_PERSIST_DIRECTORY=data/chroma
SESSION_STORE_DIRECTORY=data/sessions
COLLECTION_NAME=assistant_knowledge_base
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVER_TOP_K=4
MEMORY_WINDOW=8
TOOL_LOOP_LIMIT=4
MCP_SERVER_MODULE=app.mcp.server
